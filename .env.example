# ── Idealista account ────────────────────────────────────────────────────────
IDEALISTA_EMAIL=your@email.com
IDEALISTA_PASSWORD=yourpassword

# Your saved search URL from idealista.com (copy it from your browser)
SEARCH_URL=https://www.idealista.com/alquiler-viviendas/...

# Message sent to agents when a new listing is found
CONTACT_MESSAGE=Hola, estoy interesado en el piso. ¿Podríamos concertar una visita?

# ── Telegram bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# ── Gmail notifications ───────────────────────────────────────────────────────
# The Gmail address that receives Idealista email alerts
NOTIFY_EMAIL=your@gmail.com

# App Password (not your regular password) — generate at:
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── CapSolver (CAPTCHA auto-solver) ──────────────────────────────────────────
# Optional but strongly recommended. Sign up at capsolver.com (~$2.50/1000 solves).
# With the email-trigger model, CAPTCHAs are rare — a small balance lasts a long time.
CAPSOLVER_API_KEY=CAP-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Egress proxy (optional, strongly recommended) ────────────────────────────
# Residential proxy with Spanish exit. Without this, idealista's DataDome edge
# will eventually 403-block the NAS / home IP after a few captcha cycles.
# Commercial VPN ranges (ExpressVPN, NordVPN, etc.) are pre-flagged and DO NOT
# work — only residential proxies pass.
#
# Providers worth pricing (Spain exit, pay-as-you-go preferred for low volume):
#   IPRoyal      — ~$1.75/GB
#   Smartproxy   — ~$7/GB, ~$80/mo minimum
#   Bright Data  — premium, complex pricing
#
# Leave PROXY_SERVER unset to use the host's direct connection.
# Format: scheme://host:port (creds go in the separate vars below).
# PROXY_SERVER=http://gate.example.com:7777
# PROXY_USERNAME=your-proxy-username
# PROXY_PASSWORD=your-proxy-password

# ── Deployment ───────────────────────────────────────────────────────────────
# Required when running deploy_to_nas.sh
NAS_USER=youruser
NAS_HOST=192.168.x.x

# ── Google Sheets (optional) ─────────────────────────────────────────────────
# Follow GOOGLE_SHEETS_SETUP.md to enable cloud sync of your listings spreadsheet
# GOOGLE_SHEET_ID=your_sheet_id_here
